    "@storybook/addon-themes": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@storybook/test": "8.6.18",
    "@storybook/theming": "8.6.18",
    "storybook": "8.6.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.1.6",
    "@tailwindcss/vite": "^4.1.0",
    "tailwindcss": "^4.1.0"
